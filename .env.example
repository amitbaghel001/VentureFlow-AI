# EXIMIUS AI — Environment Configuration
# Copy this file to .env and fill in your API keys

# --- Required ---
OPENAI_API_KEY=your_openai_api_key_here

# --- Optional ---
# Use Gemini instead of OpenAI
# GEMINI_API_KEY=your_gemini_api_key_here

# Use Groq (Llama 3) instead of OpenAI
# GROQ_API_KEY=your_groq_api_key_here

# Automatic provider fallback chain: Gemini -> Groq -> Cerebras -> OpenRouter
# (kicks in only on rate-limit/quota/credits errors from the previous link).

# Cerebras — free tier, fast Llama 3.3 70B inference.
# Get a key at https://cloud.cerebras.ai
# CEREBRAS_API_KEY=your_cerebras_api_key_here

# OpenRouter — routes to many providers/models; free-tier models available.
# Get a key at https://openrouter.ai
# OPENROUTER_API_KEY=your_openrouter_api_key_here

# Kimchi (OpenAI-compatible gateway, model: kimi-k2.7) — wired in code but
# commented out of the active chain (free-tier credits exhausted).
# Get a key at https://app.kimchi.dev
# KIMCHI_API_KEY=your_kimchi_api_key_here

# --- Optional: Live data enrichment ---
# Without this, all analyses run on LLM training-data recall only (labeled "AI-INFERRED" in the UI).
# With it, startup/founder/graph analyses are grounded in live web search results (labeled "GROUNDED"/"PARTIAL").
# Get a free key at https://tavily.com (1000 requests/month free tier).
# TAVILY_API_KEY=tvly-your_key_here

# --- Optional: Access gate ---
# If set, every page requires this shared password before use (protects a
# publicly deployed app from unauthenticated API usage). If unset, the app
# is open — no login screen. Set this via Streamlit Cloud's Secrets when
# deploying publicly.
# APP_PASSWORD=choose_a_shared_password

# --- Admin gate (System Intelligence / model configuration page) ---
# Separate from APP_PASSWORD. Required to reach the model-selection page —
# unlike APP_PASSWORD, this fails CLOSED (page is inaccessible) if unset, since
# it exposes which backend model/API is powering the app. Set this via
# Streamlit Cloud's Secrets; regular users never see this page or its link.
# ADMIN_PASSWORD=choose_a_separate_admin_password

# Application settings
APP_ENV=development
LOG_LEVEL=INFO
 