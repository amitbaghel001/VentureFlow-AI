# EXIMIUS AI — Environment Configuration
# Copy this file to .env and fill in your API keys

# --- Required ---
OPENAI_API_KEY=your_openai_api_key_here

# --- Optional ---
# Use Gemini instead of OpenAI
# GEMINI_API_KEY=your_gemini_api_key_here

# Use Groq (Llama 3) instead of OpenAI
# GROQ_API_KEY=your_groq_api_key_here

# --- Optional: Live data enrichment ---
# Without this, all analyses run on LLM training-data recall only (labeled "AI-INFERRED" in the UI).
# With it, startup/founder/graph analyses are grounded in live web search results (labeled "GROUNDED"/"PARTIAL").
# Get a free key at https://tavily.com (1000 requests/month free tier).
# TAVILY_API_KEY=tvly-your_key_here

# --- Optional: Access gate ---
# If set, every page requires this shared password before use (protects a
# publicly deployed app from unauthenticated API usage). If unset, the app
# is open — no login screen. Set this via Streamlit Cloud's Secrets when
# deploying publicly.
# APP_PASSWORD=choose_a_shared_password

# Application settings
APP_ENV=development
LOG_LEVEL=INFO
 